# SineQ Environment Configuration
# Bu dosyayı .env olarak kopyala ve kendi değerlerini yaz.
# GERÇEK ŞİFRELERİ ZIP / GitHub içine koyma.

NODE_ENV=development
PORT=3000

# MongoDB Atlas veya local MongoDB
# Örnek Atlas: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/sineq?retryWrites=true&w=majority
# Örnek local: mongodb://127.0.0.1:27017/sineq
MONGODB_URI=mongodb://127.0.0.1:27017/sineq

# Site adresin. Vercel domainini buraya yaz.
# Örnek: https://senin-sineq-siten.vercel.app
APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin güvenliği
ADMIN_PASSWORD=change_this_strong_admin_password
ADMIN_JWT_SECRET=change_this_very_long_admin_secret_32_chars_min
JWT_SECRET=change_this_very_long_user_secret_32_chars_min

# Opsiyonel: TMDB metadata
TMDB_TOKEN=
TMDB_API_KEY=

# Opsiyonel: Mail ile şifre sıfırlama
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Opsiyonel: Proxy hostlarını sıkılaştırmak için
SINEQ_STRICT_PROXY_HOSTS=false
ALLOWED_PROXY_HOSTS=drive.google.com,googleusercontent.com,youtube.com,youtu.be,vimeo.com

# Opsiyonel: Firebase push
FIREBASE_SERVER_KEY=

# Opsiyonel: AI altyazı / açıklama
OPENAI_API_KEY=
